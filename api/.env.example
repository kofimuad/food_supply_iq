# --- FoodSupply IQ API ---
ENVIRONMENT=development
DEBUG=true

# Postgres + PostGIS (asyncpg driver). Host port 5440 to avoid clashing with a
# native Windows PostgreSQL on 5432 (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://fsiq:fsiq@localhost:5440/fsiq

# Redis (arq background jobs). Host port 6380 to avoid clashing with the
# sister AFDP project's Redis on 6379 (see docker-compose.yml).
REDIS_URL=redis://localhost:6380/0

# JWT signing secret (Story 0.3 — replace before any real deploy)
# JWT_SECRET=change-me

# Mapbox (geocoding / maps / route optimisation — Epics 1, 5, 10)
# MAPBOX_TOKEN=

# S3-compatible storage (MinIO / Cloudflare R2 — visit photos, Epic 3)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=fsiq-media
