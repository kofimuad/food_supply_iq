{
  "name": "food-supply-iq",
  "version": "0.1.0",
  "private": true,
  "description": "FoodSupply IQ — African food distribution intelligence (monorepo root)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "web": "pnpm --filter web dev",
    "mobile": "pnpm --filter mobile start",
    "lint:web": "pnpm --filter web lint",
    "format": "prettier --write \"web/**/*.{ts,tsx,js,jsx,json,css,md}\" \"mobile/**/*.{ts,tsx,js,jsx,json}\"",
    "gen:openapi": "cd api && python scripts/export_openapi.py",
    "gen:types": "openapi-typescript packages/api-types/openapi.json -o packages/api-types/schema.d.ts",
    "gen:api": "pnpm gen:openapi && pnpm gen:types"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.2",
    "prettier": "^3.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^18.3.0",
      "@types/react-dom": "^18.3.0"
    }
  },
  "packageManager": "pnpm@9.15.0"
}
