{
  "expo": {
    "name": "FoodSupply IQ",
    "slug": "food-supply-iq",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "fsiq",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hydra.foodsupplyiq"
    },
    "android": {
      "package": "com.hydra.foodsupplyiq",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FoodSupply IQ uses your location to log where field visits happen."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FoodSupply IQ uses your photos to attach pictures to field visits."
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://localhost:8000"
    }
  }
}
